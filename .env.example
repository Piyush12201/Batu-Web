# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# URL of your Vercel frontend (used for CORS)
CLIENT_URL=https://your-app.vercel.app

# ── Database ──────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=change_me_strong_password
DB_NAME=batu_alumni
# DB_HOST and REDIS_HOST are set automatically by docker-compose
# (service names: "postgres" and "redis")

# ── JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string

# ── Redis ─────────────────────────────────────────────────────
# Leave blank to run Redis without a password
REDIS_PASSWORD=

# ── Cloudinary (file uploads) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── File uploads ──────────────────────────────────────────────
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
